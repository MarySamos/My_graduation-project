# ========================================
# BankAgent-Pro 环境配置示例
# ========================================
# 复制此文件为 .env 并填入实际配置值

# ----------------------------------------
# 应用基础配置
# ----------------------------------------
APP_NAME=BankAgent-Pro
APP_VERSION=1.0.0
DEBUG=True

# ----------------------------------------
# 数据库配置 (必需)
# ----------------------------------------
# SQLite 示例（开发环境）
DATABASE_URL=sqlite:///./bank_agent.db

# PostgreSQL 示例（生产环境）
# DATABASE_URL=postgresql://username:password@localhost:5432/bank_agent

# ----------------------------------------
# JWT 认证配置 (必需)
# ----------------------------------------
# JWT 签名密钥 - 生产环境请使用强随机字符串（至少32位）
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-to-something-secure

# JWT 签名算法
ALGORITHM=HS256

# 访问令牌有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ----------------------------------------
# LLM API 配置 (必需)
# ----------------------------------------
# 方式1: 使用 OpenAI 兼容接口
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# 方式2: 使用智谱 AI
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# LLM 模型配置
LLM_MODEL=glm-4
LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# ----------------------------------------
# LangSmith 追踪 (可选)
# ----------------------------------------
LANGSMITH_PROJECT=
LANGSMITH_API_KEY=

# ----------------------------------------
# Checkpoint 配置
# ----------------------------------------
# memory: 内存存储（开发环境）
# postgres: PostgreSQL 持久化（生产环境）
CHECKPOINT_TYPE=memory
CHECKPOINT_DB_URL=
